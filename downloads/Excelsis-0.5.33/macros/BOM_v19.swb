Option Explicit

Private Const swDocPART As Long = 1
Private Const swDocASSEMBLY As Long = 2
Private Const swSolidBody As Long = 0
Private Const swSaveAsCurrentVersion As Long = 0
Private Const swSaveAsOptions_Silent As Long = 1
Private Const swCustomInfoText As Long = 30
Private Const swCustomPropertyReplaceValue As Long = 2
Private Const swOpenDocOptions_Silent As Long = 1
Private Const swIsometricView As Long = 7
Private Const STOCK_LENGTH_MM As Double = 6000#
Private Const SAW_KERF_MM As Double = 2#
Private Const STOCK_DP_SCALE As Long = 10
Private Const BOM_EXPORT_LANGUAGE As String = "hu"
Private Type BomItem
    key As String

    PartName As String

    configName As String

    BoundingBox As String

    L As Double

    W As Double

    H As Double

    diameter As Double

    category As String

    Qty As Long

    HiddenQty As Long

End Type

Private Type CutItem
    key As String

    Refs As String

    Profile As String

    Length As Double

    W As Double

    H As Double

    BoundingBox As String

    EndA As String

    EndB As String

    Orientation As String

    PartPath As String

    ConfigName As String

    Qty As Long

    HiddenQty As Long

End Type


Private BOM() As BomItem
Private BOM_Count As Long

Private CUTLIST() As CutItem
Private CUT_Count As Long


Private swApp As Object
Private swModel As Object


' ExcelsisAutomation updates BOM_EXPORT_LANGUAGE in this .swb from Settings.
Private Function BomLanguage() As String
    BomLanguage = LCase$(Trim$(BOM_EXPORT_LANGUAGE))
    If BomLanguage <> "en" Then BomLanguage = "hu"
End Function

